{
	"name": "@projectwallace/stylelint-plugin",
	"version": "0.0.0",
	"description": "A stylelint plugin that checks the complexity of your CSS.",
	"keywords": [
		"complexity",
		"css",
		"lint",
		"stylelint",
		"stylelint-plugin",
		"wallace"
	],
	"homepage": "https://github.com/projectwallace/stylelint-plugin",
	"license": "MIT",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.mjs",
	"exports": {
		"default": "./dist/index.mjs"
	},
	"scripts": {
		"test": "vitest --coverage",
		"check": "tsc --noEmit",
		"lint": "oxlint -D perf; oxfmt --check",
		"build": "tsdown"
	},
	"dependencies": {
		"@projectwallace/css-analyzer": "^9.4.0",
		"@projectwallace/css-parser": "^0.13.9"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^1.9.1",
		"@vitest/coverage-v8": "^4.0.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"publint": "^0.3.18",
		"stylelint": "^17.0.0",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3",
		"vitest": "^4.0.0"
	},
	"peerDependencies": {
		"stylelint": "^17.0.0"
	},
	"issues": "https://github.com/projectwallace/stylelint-plugin/issues"
}
