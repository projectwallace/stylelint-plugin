{
	"name": "@projectwallace/stylelint-plugin",
	"version": "0.4.2",
	"description": "A stylelint plugin that checks the complexity of your CSS.",
	"keywords": [
		"complexity",
		"css",
		"lint",
		"stylelint",
		"stylelint-plugin",
		"wallace"
	],
	"homepage": "https://github.com/projectwallace/stylelint-plugin",
	"bugs": "https://github.com/projectwallace/stylelint-plugin/issues",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/stylelint-plugin.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.mjs",
	"exports": {
		".": "./dist/index.mjs",
		"./configs/*": "./dist/configs/*.mjs",
		"./rules/*": "./dist/rules/*/index.mjs",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"test": "vitest --coverage",
		"check": "tsc --noEmit",
		"lint": "oxlint -D perf; oxfmt --check",
		"build": "tsdown"
	},
	"dependencies": {
		"@projectwallace/css-analyzer": "^9.8.1",
		"@projectwallace/css-parser": "^0.15.0"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^2.0.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.5",
		"oxfmt": "^0.49.0",
		"oxlint": "^1.61.0",
		"postcss": "^8.5.14",
		"publint": "^0.3.18",
		"stylelint": "~17.11.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"stylelint": "^17.0.0"
	},
	"overrides": {
		"@projectwallace/css-parser": "$@projectwallace/css-parser"
	},
	"packageManager": "pnpm@11.1.1"
}
