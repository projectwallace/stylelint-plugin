{
	"name": "@projectwallace/stylelint-plugin",
	"version": "0.6.4",
	"description": "A stylelint plugin that checks the complexity, design tokens, maintainability and correctness of your CSS.",
	"keywords": [
		"browserhacks",
		"complexity",
		"correctness",
		"css",
		"css-quality",
		"custom-properties",
		"design-tokens",
		"lint",
		"linting",
		"maintainability",
		"performance",
		"specificity",
		"stylelint",
		"stylelint-plugin",
		"vendor-prefix",
		"wallace"
	],
	"homepage": "https://github.com/projectwallace/stylelint-plugin",
	"bugs": "https://github.com/projectwallace/stylelint-plugin/issues",
	"license": "MIT",
	"author": {
		"name": "Bart Veneman",
		"email": "bart@projectwallace.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/stylelint-plugin.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.mjs",
	"exports": {
		".": "./dist/index.mjs",
		"./configs/*": "./dist/configs/*.mjs",
		"./rules/*": "./dist/rules/*/index.mjs",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"test": "vitest --coverage",
		"check": "tsc --noEmit",
		"lint": "oxlint -D perf; oxfmt --check",
		"build": "tsdown"
	},
	"dependencies": {
		"@projectwallace/css-analyzer": "^9.9.0",
		"@projectwallace/css-parser": "^0.16.0"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^2.0.1",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"postcss": "^8.5.15",
		"publint": "^0.3.21",
		"stylelint": "~17.12.0",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"stylelint": "^16.0.0 || ^17.0.0"
	},
	"overrides": {
		"@projectwallace/css-parser": "$@projectwallace/css-parser"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@11.1.1"
}
