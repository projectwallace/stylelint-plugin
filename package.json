{
	"name": "@projectwallace/stylelint-plugin",
	"version": "0.1.14",
	"description": "A stylelint plugin that checks the complexity of your CSS.",
	"keywords": [
		"complexity",
		"css",
		"lint",
		"stylelint",
		"stylelint-plugin",
		"wallace"
	],
	"homepage": "https://github.com/projectwallace/stylelint-plugin",
	"bugs": "https://github.com/projectwallace/stylelint-plugin/issues",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/projectwallace/stylelint-plugin.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.mjs",
	"exports": {
		".": "./dist/index.mjs",
		"./configs/*": "./dist/configs/*.mjs",
		"./package.json": "./package.json"
	},
	"scripts": {
		"test": "vitest --coverage",
		"check": "tsc --noEmit",
		"lint": "oxlint -D perf; oxfmt --check",
		"build": "tsdown"
	},
	"dependencies": {
		"@projectwallace/css-analyzer": "^9.6.2",
		"@projectwallace/css-parser": "^0.14.8"
	},
	"devDependencies": {
		"@codecov/rollup-plugin": "^1.9.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.0.0",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.56.0",
		"publint": "^0.3.18",
		"stylelint": "^17.0.0",
		"tsdown": "^0.21.4",
		"typescript": "^6.0.2",
		"vitest": "^4.0.0"
	},
	"peerDependencies": {
		"stylelint": "^17.0.0"
	},
	"overrides": {
		"@projectwallace/css-parser": "$@projectwallace/css-parser"
	}
}
